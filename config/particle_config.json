{
  "particles": {
    "enabled": true,
    "species_table": "src.physics.particles.particle_species.PARTICLE_SPECIES",
    "default_species": "electron",
    "default_sim_mass": 1.0,
    "use_struct_of_arrays": true,
    "initialization_mode": "deterministic_spiral_cloud",
    "initial_cloud_radius": 5.0,
    "initial_cloud_vertical_scale": 0.45,
    "initial_swirl_velocity": 0.04,
    "v0_1_initial_x_velocity": 0.05,
    "notes": "v0.5A uses collapse behavior controls to prevent uncontrolled infinitesimal collapse unless selected deliberately."
  },
  "collapse_behavior": {
    "enabled": true,
    "behavior_mode": "stable_orbit_cloud",
    "available_modes": [
      "infinite_collapse",
      "black_hole_capture",
      "stable_orbit_cloud",
      "accretion_disk",
      "field_pressure_bounce"
    ],
    "minimum_radius": 0.24,
    "capture_radius": 0.075,
    "event_horizon_visual_radius": 0.34,
    "core_pressure_strength": 0.22,
    "core_pressure_radius": 0.95,
    "orbital_floor_velocity": 0.035,
    "angular_momentum_preservation": 0.18,
    "respawn_on_capture": false,
    "respawn_radius": 5.2,
    "notes": "stable_orbit_cloud is the default. infinite_collapse can reproduce the prior collapse behavior. black_hole_capture pins captured particles near a visual horizon. respawn_on_capture can recycle particles for installation-style continuous motion."
  }
}
