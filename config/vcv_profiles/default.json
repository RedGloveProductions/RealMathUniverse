    "/ch/4": { "name": "vertical", "role": "vertical lift / bend field weight" },
    "/ch/5": { "name": "turbulence", "role": "turbulence / perturbation field weight" },
    "/ch/6": { "name": "shell", "role": "shell / horizon pressure field weight" },
    "/ch/7": { "name": "raw_aux", "role": "reserved raw modulation" },
    "/ch/8": { "name": "scene", "role": "scene / preset modulation" }
  }
