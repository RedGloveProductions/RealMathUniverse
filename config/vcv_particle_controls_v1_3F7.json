{
  "version": "v1.3F7",
  "name": "VCV Turbulence + Cohesion Controls",
  "channel_map": {
    "/ch/9": {
      "name": "particle_speed",
      "input_range": [
        -5.0,
        5.0
      ],
      "output_range": [
        0.0,
        4.0
      ],
      "description": "Existing particle speed control inherited from v1.3F5/v1.3F6."
    },
    "/ch/10": {
      "name": "particle_mass",
      "input_range": [
        -5.0,
        5.0
      ],
      "output_range": [
        0.1,
        6.0
      ],
      "description": "Existing particle mass/inertia control inherited from v1.3F5/v1.3F6."
    },
    "/ch/11": {
      "name": "particle_turbulence",
      "input_range": [
        -5.0,
        5.0
      ],
      "output_range": [
        0.0,
        2.5
      ],
      "description": "Scatter, agitation, chaotic drift, swarm instability."
    },
    "/ch/12": {
      "name": "particle_cohesion",
      "input_range": [
        -5.0,
        5.0
      ],
      "output_range": [
        0.0,
        3.0
      ],
      "description": "Gathering, clustering, accretion, gravity-like pull."
    }
  },
  "mapping_formula": "normalized = clamp((voltage + 5.0) / 10.0, 0.0, 1.0)",
  "runtime_defaults": {
    "particle_turbulence": 0.0,
    "particle_cohesion": 0.0
  }
}
