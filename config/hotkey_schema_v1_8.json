{
  "schema": "rmu.hotkey_schema.v1_8A",
  "version": "v1.8A-operator-authority-hotkey-rebuild",
  "principles": [
    "Hotkeys are final authority",
    "All hotkeys write operator_authority_state.json",
    "Old renderer-local hotkeys are overridden"
  ],
  "hotkeys": {
    "ESC": "emergency manual lock",
    "SPACE": "pause/resume physics",
    "M": "full manual authority",
    "A": "toggle behavior+field auto queues",
    "N": "toggle no-behavior",
    "TAB": "cycle active auto domain",
    "Q": "quit",
    "0-7": "set manual behavior code",
    "SHIFT+E": "toggle behavior off/on restoring last behavior",
    "B": "toggle behavior auto queue",
    "SHIFT+B": "clear behavior queue",
    "F": "toggle field auto queue",
    "SHIFT+F": "force field manual",
    "V": "cycle selected field layer",
    "SHIFT+V": "toggle selected field layer",
    "[": "previous field event",
    "]": "next field event",
    "-": "decrease selected manual field weight",
    "=": "increase selected manual field weight",
    "P": "pause/resume all queues",
    ".": "next event in active queue",
    ",": "previous event in active queue",
    "SHIFT+-": "slow active auto domain",
    "SHIFT+=": "speed active auto domain",
    "SHIFT+0": "reset active auto speed",
    "W/A/S/D": "camera movement/rotation",
    "C": "camera manual/free mode",
    "SHIFT+C": "toggle auto camera, default off",
    "CTRL+1-4": "camera presets",
    "D": "cycle dataset coupling mode",
    "SHIFT+D": "dataset observe-only",
    "G": "increase dataset gain",
    "SHIFT+G": "decrease dataset gain",
    "O": "toggle VCV event recording",
    "SHIFT+O": "clear VCV queues",
    "I": "VCV diagnostics",
    "H": "toggle HUD",
    "SHIFT+H": "cycle HUD page",
    "U": "toggle authority overlay",
    "K": "screenshot",
    "SHIFT+K": "clean screenshot",
    "CTRL+K": "burst capture"
  }
}
