{
  "render": {
    "backend": "metal_export",
    "camera": {
      "default_pan_x": 0.0,
      "default_pan_y": 0.0,
      "default_rotation_degrees": 0.0,
      "pan_step": 0.18,
      "rotation_step_degrees": 4.0,
      "zoom_step": 1.12
    },
    "clean_capture_before_hud": true,
    "color_modes": {
      "available": [
        "classic",
        "depth",
        "radial",
        "behavior",
        "thermal"
      ],
      "default": "classic"
    },
    "curvature_probability_overlays": {
      "controls": {
        "G": "toggle grid + probability halo",
        "O": "toggle center marker + horizon + curvature rings"
      },
      "curvature_ring_count": 7,
      "curvature_rings": true,
      "probability_halo": true,
      "probability_halo_points": 4200,
      "version": "0.9B"
    },
    "enabled": true,
    "field_layers": {
      "default_selected": "orbital",
      "enabled": true,
      "recipes": {
        "accretion_disk": {
          "orbital": 1.1,
          "radial": 0.35,
          "shell": 0.3,
          "turbulence": 0.1,
          "vertical": 0.25
        },
        "black_hole_capture": {
          "orbital": 0.75,
          "radial": 0.95,
          "shell": 0.4,
          "turbulence": 0.08,
          "vertical": 0.2
        },
        "field_pressure_bounce": {
          "orbital": 0.35,
          "radial": 0.55,
          "shell": 0.15,
          "turbulence": 0.3,
          "vertical": 0.45
        },
        "infinite_collapse": {
          "orbital": 0.4,
          "radial": 1.15,
          "shell": 0.45,
          "turbulence": 0.15,
          "vertical": 0.12
        },
        "stable_orbit_cloud": {
          "orbital": 1.0,
          "radial": 0.25,
          "shell": 0.2,
          "turbulence": 0.05,
          "vertical": 0.1
        }
      }
    },
    "fullscreen": false,
    "height": 1080,
    "hud_enabled": true,
    "hud_overlays": {
      "controls_overlay_enabled": true,
      "controls_width": 580,
      "enabled": true,
      "material": "hudWindow",
      "opacity": 0.78,
      "panel_margin": 18,
      "panel_top": 18,
      "stats_overlay_enabled": true,
      "stats_width": 430
    },
    "metal_export": {
      "binary_filename": "particles_xyz_f32.bin",
      "export_every_n_frames": 1,
      "metadata_filename": "metadata.json",
      "output_dir": "output/metal_live"
    },
    "notes": "v0.6A adds Metal-side particle trails, center marker, horizon ring, grid toggle, sample preset controls, and compact HUD mode.",
    "point_radius": 2,
    "render_sample_count": 25000,
    "render_world_radius": 6.0,
    "target_render_fps": 60,
    "v1_3B_note": "In geospatial_crab_field mode MetalFrameExporter renders all solver particles regardless of this preview value.",
    "visual_quality": {
      "center_marker_enabled": true,
      "compact_hud_enabled": false,
      "grid_enabled": false,
      "horizon_ring_enabled": true,
      "sample_presets": [
        25000,
        50000,
        100000
      ],
      "trail_alpha_ceiling": 0.42,
      "trail_alpha_floor": 0.08,
      "trail_length": 12,
      "trails_enabled": true
    },
    "visual_state_manager": {
      "controls": {
        "CTRL+1-5": "load visual state slot",
        "CTRL+SHIFT+1-5": "save visual state slot",
        "SHIFT+6": "gallery orbit camera",
        "SHIFT+7": "macro disk camera",
        "SHIFT+8": "wide system camera",
        "SHIFT+9": "reset default camera",
        "SHIFT+D": "toggle auto-camera drift"
      },
      "directory": "config/visual_states",
      "enabled": true,
      "state_slots": 5,
      "version": "0.9B"
    },
    "width": 1920,
    "windowed": true
  },
  "session": {
    "default_size": "1920x1080",
    "full_session_script": "scripts/run_full_vcv_metal_session.sh",
    "vcv_bridge_required_for_external_control": true
  },
  "version": "0.9B",
  "v1_3F7_particle_controls": {
    "version": "v1.3F7",
    "name": "VCV Turbulence + Cohesion Controls",
    "channel_map": {
      "/ch/9": {
        "name": "particle_speed",
        "input_range": [
          -5.0,
          5.0
        ],
        "output_range": [
          0.0,
          4.0
        ],
        "description": "Existing particle speed control inherited from v1.3F5/v1.3F6."
      },
      "/ch/10": {
        "name": "particle_mass",
        "input_range": [
          -5.0,
          5.0
        ],
        "output_range": [
          0.1,
          6.0
        ],
        "description": "Existing particle mass/inertia control inherited from v1.3F5/v1.3F6."
      },
      "/ch/11": {
        "name": "particle_turbulence",
        "input_range": [
          -5.0,
          5.0
        ],
        "output_range": [
          0.0,
          2.5
        ],
        "description": "Scatter, agitation, chaotic drift, swarm instability."
      },
      "/ch/12": {
        "name": "particle_cohesion",
        "input_range": [
          -5.0,
          5.0
        ],
        "output_range": [
          0.0,
          3.0
        ],
        "description": "Gathering, clustering, accretion, gravity-like pull."
      }
    },
    "mapping_formula": "normalized = clamp((voltage + 5.0) / 10.0, 0.0, 1.0)",
    "runtime_defaults": {
      "particle_turbulence": 0.0,
      "particle_cohesion": 0.0
    }
  }
}
